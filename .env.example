# CẤU HÌNH KẾT NỐI CƠ SỞ DỮ LIỆU GITMINI
# Lưu ý: Tạo file .env từ file này và điền thông tin thực tế. 
# KHÔNG ĐẨY FILE .ENV LÊN GIT ĐỂ BẢO MẬT.

# Chuỗi kết nối đầy đủ (Dành cho FastAPI / SQLAlchemy / Prisma)
DATABASE_URL=postgresql://your_user:your_password@localhost:5432/gitmini_db

# Thông tin chi tiết (Dành cho các script quản trị)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gitmini_db
DB_USER=your_user
DB_PASS=your_password

# Cấu hình bảo mật ứng dụng
SECRET_KEY=generate_a_strong_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
