<mxfile host="app.diagrams.net" modified="2026-04-30T00:00:00.000Z" agent="Claude Code" version="24.7.17" type="device">
  <diagram id="gitmini-erd" name="GitMini ERD">
    <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="GitMini ERD - Tổng quan bảng dữ liệu PostgreSQL" style="text;html=1;strokeColor=none;fillColor=none;fontSize=24;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="430" y="20" width="740" height="40" as="geometry" />
        </mxCell>
        <mxCell id="users" value="users&#xa;PK id UUID&#xa;username UNIQUE&#xa;email UNIQUE&#xa;password_hash&#xa;system_role/demo info" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="230" height="150" as="geometry" />
        </mxCell>
        <mxCell id="repositories" value="repositories&#xa;PK id UUID&#xa;FK owner_id -> users.id&#xa;name&#xa;is_private&#xa;default_branch&#xa;UNIQUE(owner_id, name)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="400" y="100" width="270" height="170" as="geometry" />
        </mxCell>
        <mxCell id="repo_members" value="repo_members&#xa;PK (repo_id, user_id)&#xa;FK repo_id -> repositories.id&#xa;FK user_id -> users.id&#xa;role CHECK owner/maintainer/&#xa;developer/reviewer/viewer&#xa;joined_at" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="60" y="330" width="300" height="180" as="geometry" />
        </mxCell>
        <mxCell id="commits" value="commits&#xa;PK commit_hash CHAR(40)&#xa;FK repo_id -> repositories.id&#xa;FK author_id -> users.id&#xa;message&#xa;created_at" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="790" y="100" width="270" height="150" as="geometry" />
        </mxCell>
        <mxCell id="commit_parents" value="commit_parents&#xa;PK (commit_hash, parent_hash)&#xa;FK commit_hash -> commits.commit_hash&#xa;FK parent_hash -> commits.commit_hash&#xa;ordinal&#xa;Biểu diễn DAG commit graph" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="1140" y="100" width="340" height="160" as="geometry" />
        </mxCell>
        <mxCell id="branches" value="branches&#xa;PK id UUID&#xa;FK repo_id -> repositories.id&#xa;FK head_commit_hash -> commits.commit_hash&#xa;name&#xa;is_protected&#xa;UNIQUE(repo_id, name)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="760" y="330" width="310" height="170" as="geometry" />
        </mxCell>
        <mxCell id="issues" value="issues&#xa;PK id UUID&#xa;FK repo_id -> repositories.id&#xa;FK author_id -> users.id&#xa;FK assignee_id -> users.id&#xa;title, body&#xa;status CHECK open/closed&#xa;labels TEXT[]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="400" y="570" width="300" height="190" as="geometry" />
        </mxCell>
        <mxCell id="pull_requests" value="pull_requests&#xa;PK id UUID&#xa;FK repo_id -> repositories.id&#xa;FK author_id -> users.id&#xa;FK merge_commit_hash -> commits.commit_hash&#xa;source_branch, target_branch&#xa;status CHECK open/closed/merged" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="790" y="570" width="340" height="190" as="geometry" />
        </mxCell>
        <mxCell id="pull_request_reviews" value="pull_request_reviews&#xa;PK id UUID&#xa;FK pull_request_id -> pull_requests.id&#xa;FK reviewer_id -> users.id&#xa;status CHECK approved&#xa;UNIQUE(pull_request_id, reviewer_id)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="1200" y="570" width="330" height="160" as="geometry" />
        </mxCell>
        <mxCell id="audit_logs" value="audit_logs&#xa;PK id UUID&#xa;FK actor_id -> users.id&#xa;FK repo_id -> repositories.id&#xa;action&#xa;target_type, target_id&#xa;metadata JSONB&#xa;created_at" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="60" y="800" width="300" height="180" as="geometry" />
        </mxCell>
        <mxCell id="repo_stats" value="repo_stats&#xa;PK/FK repo_id -> repositories.id&#xa;commit_count&#xa;branch_count&#xa;issue_open_count / closed&#xa;pr_open_count / merged&#xa;latest_commit_*&#xa;updated_at&#xa;Phi chuẩn hóa có trigger kiểm soát" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="420" y="820" width="360" height="210" as="geometry" />
        </mxCell>
        <mxCell id="note" value="Ghi chú: backend/frontend chỉ là lớp minh chứng. Trọng tâm CSDL gồm schema, constraint, index, trigger, RLS/RBAC, audit, backup/restore và benchmark." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="860" y="830" width="560" height="90" as="geometry" />
        </mxCell>
        <mxCell id="e1" value="owns 1-n" style="endArrow=block;html=1;rounded=0;strokeWidth=2" edge="1" parent="1" source="users" target="repositories"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" value="member user" style="endArrow=block;html=1;rounded=0;strokeWidth=2" edge="1" parent="1" source="users" target="repo_members"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" value="has members" style="endArrow=block;html=1;rounded=0;strokeWidth=2" edge="1" parent="1" source="repositories" target="repo_members"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4" value="contains commits" style="endArrow=block;html=1;rounded=0;strokeWidth=2" edge="1" parent="1" source="repositories" target="commits"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e5" value="DAG parent edges" style="endArrow=block;html=1;rounded=0;strokeWidth=2" edge="1" parent="1" source="commits" target="commit_parents"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e6" value="has branches" style="endArrow=block;html=1;rounded=0;strokeWidth=2" edge="1" parent="1" source="repositories" target="branches"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e7" value="branch head" style="endArrow=block;html=1;rounded=0;strokeWidth=2" edge="1" parent="1" source="branches" target="commits"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e8" value="has issues" style="endArrow=block;html=1;rounded=0;strokeWidth=2" edge="1" parent="1" source="repositories" target="issues"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e9" value="has PRs" style="endArrow=block;html=1;rounded=0;strokeWidth=2" edge="1" parent="1" source="repositories" target="pull_requests"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e10" value="reviews" style="endArrow=block;html=1;rounded=0;strokeWidth=2" edge="1" parent="1" source="pull_requests" target="pull_request_reviews"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e11" value="reviewer" style="endArrow=block;html=1;rounded=0;strokeWidth=2" edge="1" parent="1" source="users" target="pull_request_reviews"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e12" value="audit actor" style="endArrow=block;html=1;rounded=0;strokeWidth=2" edge="1" parent="1" source="users" target="audit_logs"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e13" value="audit repo" style="endArrow=block;html=1;rounded=0;strokeWidth=2" edge="1" parent="1" source="repositories" target="audit_logs"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e14" value="1-1 stats" style="endArrow=block;html=1;rounded=0;strokeWidth=2" edge="1" parent="1" source="repositories" target="repo_stats"><mxGeometry relative="1" as="geometry" /></mxCell>
