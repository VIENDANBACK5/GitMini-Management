<mxfile host="app.diagrams.net" modified="2026-04-30T00:00:00.000Z" agent="draw.io" version="24.7.17" type="device">
  <diagram id="gitmini-team-db-responsibility" name="GitMini Team DB Responsibility">
    <mxGraphModel dx="1500" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="950" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Phân công 4 thành viên theo nhánh Quản trị CSDL" style="text;html=1;strokeColor=none;fillColor=none;fontSize=24;fontStyle=1" vertex="1" parent="1"><mxGeometry x="330" y="20" width="760" height="40" as="geometry" /></mxCell>
        <mxCell id="center" value="GitMini PostgreSQL Database&#xa;Trọng tâm môn Quản trị CSDL&#xa;Schema • Index • Trigger • Security • Backup • Analytics" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=16;fontStyle=1" vertex="1" parent="1"><mxGeometry x="510" y="340" width="360" height="180" as="geometry" /></mxCell>
        <mxCell id="m1" value="Thành viên 1&#xa;Phân tích nghiệp vụ CSDL&#xa;&#xa;- Yêu cầu dữ liệu&#xa;- Thực thể / thuộc tính&#xa;- Quan hệ&#xa;- Chuẩn hóa 3NF&#xa;- Data dictionary&#xa;- Mapping yêu cầu bài tập" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;align=left;spacingLeft=12" vertex="1" parent="1"><mxGeometry x="80" y="130" width="330" height="230" as="geometry" /></mxCell>
        <mxCell id="m2" value="Thành viên 2&#xa;Thiết kế &amp; vận hành PostgreSQL&#xa;&#xa;- Schema vật lý&#xa;- PK / FK / UNIQUE / CHECK&#xa;- Index B-tree / GIN&#xa;- Trigger / repo_stats&#xa;- Migration / seed&#xa;- Backup / restore / Docker DB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;align=left;spacingLeft=12" vertex="1" parent="1"><mxGeometry x="970" y="130" width="350" height="250" as="geometry" /></mxCell>
        <mxCell id="m3" value="Thành viên 3&#xa;Bảo mật &amp; kiểm soát dữ liệu&#xa;&#xa;- RBAC PostgreSQL&#xa;- Row Level Security&#xa;- Repository membership&#xa;- Permission workflow&#xa;- Audit log&#xa;- Test quyền truy cập dữ liệu" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;align=left;spacingLeft=12" vertex="1" parent="1"><mxGeometry x="80" y="580" width="330" height="240" as="geometry" /></mxCell>
        <mxCell id="m4" value="Thành viên 4&#xa;Khai thác dữ liệu &amp; minh chứng truy vấn&#xa;&#xa;- Query repository/history&#xa;- Query issue / pull request&#xa;- Analytics dashboard&#xa;- Full-text search minh chứng&#xa;- Screenshot dữ liệu CSDL&#xa;- Demo luồng khai thác dữ liệu" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;align=left;spacingLeft=12" vertex="1" parent="1"><mxGeometry x="970" y="580" width="350" height="250" as="geometry" /></mxCell>
        <mxCell id="review1" value="Review chéo: TV1 → TV4&#xa;Kiểm tra minh chứng UI có giải thích được bằng dữ liệu CSDL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf" vertex="1" parent="1"><mxGeometry x="455" y="110" width="470" height="70" as="geometry" /></mxCell>
        <mxCell id="review2" value="Review chéo: TV2 → TV1&#xa;Kiểm tra mô hình logic chuyển được thành schema PostgreSQL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366" vertex="1" parent="1"><mxGeometry x="455" y="200" width="470" height="70" as="geometry" /></mxCell>
        <mxCell id="review3" value="Review chéo: TV3 → TV2&#xa;Kiểm tra schema/migration đáp ứng bảo mật và quyền dữ liệu" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450" vertex="1" parent="1"><mxGeometry x="455" y="590" width="470" height="70" as="geometry" /></mxCell>
        <mxCell id="review4" value="Review chéo: TV4 → TV3&#xa;Kiểm tra dữ liệu trả ra UI đúng quyền, không lộ repo private" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00" vertex="1" parent="1"><mxGeometry x="455" y="680" width="470" height="70" as="geometry" /></mxCell>
        <mxCell id="note" value="Thông điệp: Cả 4 thành viên đều làm CSDL. Backend/frontend chỉ là cách kiểm chứng và trình bày kết quả quản trị dữ liệu." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=14" vertex="1" parent="1"><mxGeometry x="360" y="850" width="680" height="60" as="geometry" /></mxCell>
        <mxCell id="e1" value="phân tích" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="m1" target="center"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" value="thiết kế/vận hành" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="m2" target="center"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" value="bảo mật" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="m3" target="center"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4" value="khai thác" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="m4" target="center"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
