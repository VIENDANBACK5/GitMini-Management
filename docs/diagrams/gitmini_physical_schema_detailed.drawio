<mxfile host="app.diagrams.net" modified="2026-04-30T00:00:00.000Z" agent="draw.io" version="24.7.17" type="device">
  <diagram id="gitmini-physical-schema-20" name="GitMini Physical Schema 20 Tables">
    <mxGraphModel dx="3200" dy="2400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3000" pageHeight="2200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="GitMini - Lược đồ quan hệ vật lý PostgreSQL 20 bảng" style="text;html=1;strokeColor=none;fillColor=none;fontSize=28;fontStyle=1" vertex="1" parent="1"><mxGeometry x="760" y="20" width="1400" height="50" as="geometry" /></mxCell>
        <mxCell id="legend" value="Ký hiệu&#xa;PK = khóa chính&#xa;FK = khóa ngoại&#xa;UQ = UNIQUE&#xa;CK = CHECK&#xa;IDX = index tối ưu truy vấn&#xa;JSONB = metadata vận hành&#xa;PARTITION = chiến lược phân vùng khi dữ liệu lớn" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=12;fontSize=14" vertex="1" parent="1"><mxGeometry x="2400" y="90" width="470" height="190" as="geometry" /></mxCell>

        <mxCell id="users" value="users&#xa;PK id UUID&#xa;UQ username, email&#xa;password_hash, full_name, bio&#xa;is_active, created_at, updated_at&#xa;IDX username/email unique" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="1"><mxGeometry x="40" y="120" width="320" height="170" as="geometry" /></mxCell>
        <mxCell id="repositories" value="repositories&#xa;PK id UUID&#xa;FK owner_id -> users.id&#xa;name, description, is_private&#xa;default_branch, stars_count, forks_count&#xa;UQ(owner_id, name)&#xa;IDX idx_repos_owner&#xa;PARTITION đề xuất: HASH(owner_id/id)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="1"><mxGeometry x="430" y="110" width="360" height="230" as="geometry" /></mxCell>
        <mxCell id="repo_members" value="repo_members&#xa;PK/FK repo_id -> repositories.id&#xa;PK/FK user_id -> users.id&#xa;role CK owner/maintainer/developer/reviewer/viewer&#xa;joined_at&#xa;IDX(user_id, role), IDX(repo_id, role)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="1"><mxGeometry x="40" y="360" width="360" height="200" as="geometry" /></mxCell>
        <mxCell id="commits" value="commits&#xa;PK commit_hash CHAR(40)&#xa;FK repo_id -> repositories.id&#xa;FK author_id -> users.id&#xa;message, created_at&#xa;IDX(repo_id), IDX(author_id), IDX(repo_id, created_at DESC)&#xa;GIN message search&#xa;PARTITION đề xuất: HASH(repo_id) / RANGE(created_at)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="1"><mxGeometry x="860" y="110" width="410" height="250" as="geometry" /></mxCell>
        <mxCell id="commit_parents" value="commit_parents&#xa;PK/FK commit_hash -> commits.commit_hash&#xa;PK/FK parent_hash -> commits.commit_hash&#xa;ordinal&#xa;IDX commit_hash, parent_hash&#xa;Biểu diễn DAG commit graph" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="1"><mxGeometry x="1350" y="120" width="370" height="190" as="geometry" /></mxCell>
        <mxCell id="branches" value="branches&#xa;PK id UUID&#xa;FK repo_id -> repositories.id&#xa;FK head_commit_hash -> commits.commit_hash&#xa;name, is_protected&#xa;UQ(repo_id, name)&#xa;IDX repo_id" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="1"><mxGeometry x="860" y="410" width="370" height="210" as="geometry" /></mxCell>
        <mxCell id="file_blobs" value="file_blobs&#xa;PK id UUID&#xa;UQ blob_hash CHAR(40)&#xa;content TEXT, size_bytes BIGINT CK >= 0&#xa;mime_type, created_at&#xa;IDX blob_hash" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="1"><mxGeometry x="1800" y="120" width="340" height="180" as="geometry" /></mxCell>
        <mxCell id="commit_files" value="commit_files&#xa;PK/FK commit_hash -> commits.commit_hash&#xa;PK file_path TEXT&#xa;FK blob_id -> file_blobs.id&#xa;change_type CK added/modified/deleted/renamed&#xa;additions/deletions CK >= 0&#xa;IDX blob_id, file_path" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="1"><mxGeometry x="1800" y="350" width="390" height="230" as="geometry" /></mxCell>
        <mxCell id="repository_languages" value="repository_languages&#xa;PK/FK repo_id -> repositories.id&#xa;PK language VARCHAR(50)&#xa;bytes_count CK >= 0&#xa;percentage NUMERIC(5,2) CK 0..100&#xa;IDX language" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="1"><mxGeometry x="430" y="390" width="370" height="190" as="geometry" /></mxCell>

        <mxCell id="issues" value="issues&#xa;PK id UUID&#xa;FK repo_id -> repositories.id&#xa;FK author_id/assignee_id -> users.id&#xa;title, body, status CK open/closed&#xa;labels TEXT[], created/updated/closed_at&#xa;IDX(repo_id), IDX(repo_id,status)&#xa;GIN title/body search&#xa;PARTITION đề xuất: HASH(repo_id) / RANGE(created_at)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="1"><mxGeometry x="40" y="700" width="400" height="270" as="geometry" /></mxCell>
        <mxCell id="issue_comments" value="issue_comments&#xa;PK id UUID&#xa;FK issue_id -> issues.id&#xa;FK author_id -> users.id&#xa;body, created_at, updated_at&#xa;IDX(issue_id, created_at DESC), IDX author_id" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="1"><mxGeometry x="510" y="730" width="360" height="190" as="geometry" /></mxCell>
        <mxCell id="pull_requests" value="pull_requests&#xa;PK id UUID&#xa;FK repo_id -> repositories.id&#xa;FK author_id -> users.id&#xa;source_branch, target_branch&#xa;status CK open/closed/merged&#xa;FK merge_commit_hash -> commits.commit_hash&#xa;IDX(repo_id), IDX(repo_id,status)&#xa;PARTITION đề xuất: HASH(repo_id)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="1"><mxGeometry x="940" y="700" width="400" height="260" as="geometry" /></mxCell>
        <mxCell id="pull_request_reviews" value="pull_request_reviews&#xa;PK id UUID&#xa;FK pull_request_id -> pull_requests.id&#xa;FK reviewer_id -> users.id&#xa;status CK approved&#xa;UQ(pull_request_id, reviewer_id)&#xa;IDX pull_request_id, reviewer_id" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="1"><mxGeometry x="1410" y="690" width="390" height="210" as="geometry" /></mxCell>
        <mxCell id="pull_request_comments" value="pull_request_comments&#xa;PK id UUID&#xa;FK pull_request_id -> pull_requests.id&#xa;FK author_id -> users.id&#xa;body, file_path, line_number CK > 0&#xa;created_at, updated_at&#xa;IDX(pull_request_id, created_at DESC), IDX author_id" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="1"><mxGeometry x="1880" y="690" width="410" height="230" as="geometry" /></mxCell>

        <mxCell id="tags" value="tags&#xa;PK id UUID&#xa;FK repo_id -> repositories.id&#xa;name VARCHAR(100)&#xa;FK target_commit_hash -> commits.commit_hash&#xa;FK created_by -> users.id&#xa;UQ(repo_id, name)&#xa;IDX repo_id, target_commit_hash" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="1"><mxGeometry x="40" y="1100" width="360" height="220" as="geometry" /></mxCell>
        <mxCell id="releases" value="releases&#xa;PK id UUID&#xa;FK repo_id -> repositories.id&#xa;FK tag_id -> tags.id&#xa;title, description, is_prerelease&#xa;FK published_by -> users.id&#xa;published_at&#xa;IDX repo_id, tag_id" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="1"><mxGeometry x="470" y="1110" width="360" height="210" as="geometry" /></mxCell>
        <mxCell id="ci_runs" value="ci_runs&#xa;PK id UUID&#xa;FK repo_id -> repositories.id&#xa;FK commit_hash -> commits.commit_hash&#xa;FK pull_request_id -> pull_requests.id&#xa;status CK queued/running/success/failed/cancelled&#xa;started_at, finished_at, metadata JSONB&#xa;IDX(repo_id,status), IDX commit_hash, IDX pull_request_id" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="1"><mxGeometry x="920" y="1080" width="430" height="260" as="geometry" /></mxCell>
        <mxCell id="audit_logs" value="audit_logs&#xa;PK id UUID&#xa;FK actor_id -> users.id&#xa;FK repo_id -> repositories.id&#xa;action, target_type, target_id&#xa;metadata JSONB, created_at&#xa;IDX created_at, actor/time, repo/time, action/time&#xa;PARTITION đề xuất: RANGE(created_at) theo tháng/quý" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="1"><mxGeometry x="1430" y="1050" width="410" height="260" as="geometry" /></mxCell>
        <mxCell id="backup_jobs" value="backup_jobs&#xa;PK id UUID&#xa;job_type CK full/restore_test&#xa;status CK running/success/failed&#xa;backup_path, started_at, finished_at&#xa;metadata JSONB&#xa;IDX started_at DESC, IDX(status, started_at DESC)&#xa;PARTITION đề xuất: RANGE(started_at) nếu log lớn" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="1"><mxGeometry x="1920" y="1050" width="410" height="240" as="geometry" /></mxCell>
        <mxCell id="repo_stats" value="repo_stats&#xa;PK/FK repo_id -> repositories.id&#xa;commit_count, branch_count&#xa;issue_open_count, issue_closed_count&#xa;pr_open_count, pr_merged_count&#xa;latest_commit_hash/time/msg&#xa;updated_at&#xa;IDX updated_at DESC&#xa;Phi chuẩn hóa có trigger kiểm soát" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="1"><mxGeometry x="2400" y="1050" width="390" height="260" as="geometry" /></mxCell>

        <mxCell id="partition" value="Chiến lược quản trị / phân vùng khi dữ liệu lớn&#xa;1. commits, commit_files: HASH(repo_id thông qua commit) hoặc RANGE(created_at) cho lịch sử lớn.&#xa;2. issues, pull_requests, comments, ci_runs: HASH(repo_id) hoặc RANGE(created_at/started_at).&#xa;3. audit_logs, backup_jobs: RANGE theo tháng/quý vì tăng liên tục và hay truy vấn theo thời gian.&#xa;4. repo_stats không partition: một dòng/repo, phục vụ dashboard nhanh.&#xa;5. RLS/RBAC bảo vệ repo private; audit_logs/backup_jobs phục vụ quản trị và truy vết.&#xa;6. Migration idempotent: CREATE IF NOT EXISTS + index IF NOT EXISTS; test smoke kiểm tra đủ 20 bảng." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=12;fontSize=14;fontStyle=1" vertex="1" parent="1"><mxGeometry x="250" y="1500" width="2350" height="210" as="geometry" /></mxCell>

        <mxCell id="e1" value="owner_id" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="repositories" target="users"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" value="repo_id" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="repo_members" target="repositories"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" value="user_id" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="repo_members" target="users"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4" value="repo_id" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="commits" target="repositories"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e5" value="author_id" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="commits" target="users"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e6" value="parent/child" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="commit_parents" target="commits"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e7" value="head_commit" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="branches" target="commits"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e8" value="repo_id" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="branches" target="repositories"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e9" value="commit_hash" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="commit_files" target="commits"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e10" value="blob_id" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="commit_files" target="file_blobs"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e11" value="repo_id" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="repository_languages" target="repositories"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e12" value="repo_id" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="issues" target="repositories"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e13" value="author/assignee" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="issues" target="users"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e14" value="issue_id" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="issue_comments" target="issues"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e15" value="repo_id" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="pull_requests" target="repositories"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e16" value="merge_commit" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="pull_requests" target="commits"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e17" value="pull_request_id" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="pull_request_reviews" target="pull_requests"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e18" value="pull_request_id" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="pull_request_comments" target="pull_requests"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e19" value="repo_id" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="tags" target="repositories"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e20" value="target_commit" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="tags" target="commits"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e21" value="tag_id" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="releases" target="tags"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e22" value="repo_id" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="ci_runs" target="repositories"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e23" value="commit_hash" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="ci_runs" target="commits"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e24" value="pull_request_id" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="ci_runs" target="pull_requests"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e25" value="repo_id" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="audit_logs" target="repositories"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e26" value="actor_id" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="audit_logs" target="users"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e27" value="repo_id" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="repo_stats" target="repositories"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
