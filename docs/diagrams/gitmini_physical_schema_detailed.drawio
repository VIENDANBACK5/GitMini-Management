<mxfile host="app.diagrams.net" modified="2026-04-30T00:00:00.000Z" agent="Claude Code" version="24.7.17" type="device">
  <diagram id="gitmini-physical-schema" name="GitMini Physical Schema Detailed">
    <mxGraphModel dx="2600" dy="1800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="1700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="GitMini - Lược đồ quan hệ vật lý chi tiết PostgreSQL" style="text;html=1;strokeColor=none;fillColor=none;fontSize=28;fontStyle=1" vertex="1" parent="1"><mxGeometry x="700" y="20" width="1000" height="50" as="geometry" /></mxCell>
        <mxCell id="legend" value="Ký hiệu&#xa;PK = khóa chính&#xa;FK = khóa ngoại&#xa;UQ = UNIQUE&#xa;CK = CHECK&#xa;IDX = index tối ưu truy vấn&#xa;PARTITION = chiến lược phân vùng đề xuất khi dữ liệu lớn" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=12;fontSize=14" vertex="1" parent="1"><mxGeometry x="1870" y="90" width="420" height="170" as="geometry" /></mxCell>

        <mxCell id="users" value="users&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;PK id UUID DEFAULT uuid_generate_v4()&#xa;UQ username VARCHAR(50) NOT NULL&#xa;UQ email VARCHAR(255) NOT NULL&#xa;password_hash VARCHAR(255) NOT NULL&#xa;full_name VARCHAR(100)&#xa;bio TEXT DEFAULT ''&#xa;avatar_url VARCHAR(500)&#xa;is_active BOOLEAN DEFAULT TRUE&#xa;created_at TIMESTAMPTZ DEFAULT NOW()&#xa;updated_at TIMESTAMPTZ DEFAULT NOW()&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;Quan hệ: owner, member, author, reviewer, actor" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="1"><mxGeometry x="40" y="120" width="390" height="290" as="geometry" /></mxCell>
        <mxCell id="repositories" value="repositories&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;PK id UUID DEFAULT uuid_generate_v4()&#xa;name VARCHAR(100) NOT NULL&#xa;description TEXT DEFAULT ''&#xa;FK owner_id UUID NOT NULL -> users.id&#xa;is_private BOOLEAN DEFAULT FALSE&#xa;default_branch VARCHAR(100) DEFAULT 'main'&#xa;stars_count INT DEFAULT 0&#xa;forks_count INT DEFAULT 0&#xa;created_at TIMESTAMPTZ DEFAULT NOW()&#xa;updated_at TIMESTAMPTZ DEFAULT NOW()&#xa;UQ (owner_id, name)&#xa;IDX idx_repos_owner(owner_id)&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;PARTITION đề xuất: HASH(id) hoặc theo owner_id nếu số repo rất lớn" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="1"><mxGeometry x="520" y="120" width="430" height="330" as="geometry" /></mxCell>
        <mxCell id="repo_members" value="repo_members&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;PK repo_id UUID -> repositories.id&#xa;PK user_id UUID -> users.id&#xa;role VARCHAR(20) NOT NULL&#xa;CK role IN owner/maintainer/developer/reviewer/viewer&#xa;joined_at TIMESTAMPTZ DEFAULT NOW()&#xa;IDX idx_repo_members_user_role(user_id, role)&#xa;IDX idx_repo_members_repo_role(repo_id, role)&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;Bảng nối nhiều-nhiều users ↔ repositories&#xa;Role phụ thuộc cặp user-repo" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="1"><mxGeometry x="40" y="500" width="430" height="280" as="geometry" /></mxCell>
        <mxCell id="commits" value="commits&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;PK commit_hash CHAR(40)&#xa;FK repo_id UUID NOT NULL -> repositories.id&#xa;FK author_id UUID -> users.id ON DELETE SET NULL&#xa;message TEXT NOT NULL&#xa;created_at TIMESTAMPTZ DEFAULT NOW()&#xa;IDX idx_commits_repo(repo_id)&#xa;IDX idx_commits_author(author_id)&#xa;IDX idx_commits_repo_time(repo_id, created_at DESC)&#xa;GIN idx_commits_message_search(to_tsvector(message))&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;PARTITION đề xuất: HASH(repo_id) hoặc RANGE(created_at) khi commit rất lớn" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="1"><mxGeometry x="1040" y="120" width="470" height="310" as="geometry" /></mxCell>
        <mxCell id="commit_parents" value="commit_parents&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;PK commit_hash CHAR(40) -> commits.commit_hash&#xa;PK parent_hash CHAR(40) -> commits.commit_hash&#xa;ordinal INT DEFAULT 0&#xa;IDX idx_parents_commit(commit_hash)&#xa;IDX idx_parents_parent(parent_hash)&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;Biểu diễn DAG commit graph&#xa;Merge commit có thể có nhiều parent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="1"><mxGeometry x="1600" y="120" width="430" height="240" as="geometry" /></mxCell>
        <mxCell id="branches" value="branches&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;PK id UUID DEFAULT uuid_generate_v4()&#xa;FK repo_id UUID NOT NULL -> repositories.id&#xa;name VARCHAR(255) NOT NULL&#xa;FK head_commit_hash CHAR(40) -> commits.commit_hash&#xa;is_protected BOOLEAN DEFAULT FALSE&#xa;created_at TIMESTAMPTZ DEFAULT NOW()&#xa;updated_at TIMESTAMPTZ DEFAULT NOW()&#xa;UQ (repo_id, name)&#xa;IDX idx_branches_repo(repo_id)&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;Protected branch dùng cho PR governance" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="1"><mxGeometry x="1040" y="500" width="460" height="300" as="geometry" /></mxCell>
        <mxCell id="issues" value="issues&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;PK id UUID DEFAULT uuid_generate_v4()&#xa;FK repo_id UUID NOT NULL -> repositories.id&#xa;FK author_id UUID -> users.id ON DELETE SET NULL&#xa;FK assignee_id UUID -> users.id ON DELETE SET NULL&#xa;title VARCHAR(500) NOT NULL&#xa;body TEXT DEFAULT ''&#xa;status VARCHAR(20) DEFAULT 'open'&#xa;CK status IN open/closed&#xa;labels TEXT[] DEFAULT '{}'&#xa;created_at TIMESTAMPTZ DEFAULT NOW()&#xa;updated_at TIMESTAMPTZ DEFAULT NOW()&#xa;closed_at TIMESTAMPTZ&#xa;IDX idx_issues_repo(repo_id)&#xa;IDX idx_issues_repo_status(repo_id, status)&#xa;GIN idx_issues_search(to_tsvector(title || body))&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;PARTITION đề xuất: RANGE(created_at) hoặc HASH(repo_id) khi issue lớn" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="1"><mxGeometry x="520" y="870" width="500" height="410" as="geometry" /></mxCell>
        <mxCell id="pull_requests" value="pull_requests&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;PK id UUID DEFAULT uuid_generate_v4()&#xa;FK repo_id UUID NOT NULL -> repositories.id&#xa;FK author_id UUID -> users.id ON DELETE SET NULL&#xa;title VARCHAR(500) NOT NULL&#xa;body TEXT DEFAULT ''&#xa;status VARCHAR(20) DEFAULT 'open'&#xa;CK status IN open/closed/merged&#xa;source_branch VARCHAR(255) NOT NULL&#xa;target_branch VARCHAR(255) DEFAULT 'main'&#xa;FK merge_commit_hash CHAR(40) -> commits.commit_hash&#xa;created_at TIMESTAMPTZ DEFAULT NOW()&#xa;updated_at TIMESTAMPTZ DEFAULT NOW()&#xa;merged_at TIMESTAMPTZ&#xa;closed_at TIMESTAMPTZ&#xa;IDX idx_pr_repo(repo_id)&#xa;IDX idx_pr_repo_status(repo_id, status)&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;PARTITION đề xuất: HASH(repo_id) khi PR lớn" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="1"><mxGeometry x="1100" y="870" width="510" height="430" as="geometry" /></mxCell>
        <mxCell id="pull_request_reviews" value="pull_request_reviews&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;PK id UUID DEFAULT uuid_generate_v4()&#xa;FK pull_request_id UUID NOT NULL -> pull_requests.id&#xa;FK reviewer_id UUID -> users.id ON DELETE SET NULL&#xa;status VARCHAR(20) NOT NULL&#xa;CK status IN approved&#xa;created_at TIMESTAMPTZ DEFAULT NOW()&#xa;UQ (pull_request_id, reviewer_id)&#xa;IDX idx_pr_reviews_pull_request(pull_request_id)&#xa;IDX idx_pr_reviews_reviewer(reviewer_id)&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;Chặn self-approval ở backend rule&#xa;Yêu cầu approval trước khi merge protected branch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="1"><mxGeometry x="1680" y="870" width="500" height="330" as="geometry" /></mxCell>
        <mxCell id="audit_logs" value="audit_logs&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;PK id UUID DEFAULT uuid_generate_v4()&#xa;FK actor_id UUID -> users.id ON DELETE SET NULL&#xa;FK repo_id UUID -> repositories.id ON DELETE SET NULL&#xa;action VARCHAR(50) NOT NULL&#xa;target_type VARCHAR(50) NOT NULL&#xa;target_id TEXT&#xa;metadata JSONB DEFAULT '{}'::jsonb&#xa;created_at TIMESTAMPTZ DEFAULT NOW()&#xa;IDX idx_audit_logs_created_at(created_at DESC)&#xa;IDX idx_audit_logs_actor_created(actor_id, created_at DESC)&#xa;IDX idx_audit_logs_repo_created(repo_id, created_at DESC)&#xa;IDX idx_audit_logs_action_created(action, created_at DESC)&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;PARTITION đề xuất: RANGE(created_at) theo tháng/quý khi log lớn" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="1"><mxGeometry x="40" y="880" width="430" height="390" as="geometry" /></mxCell>
        <mxCell id="repo_stats" value="repo_stats&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;PK/FK repo_id UUID -> repositories.id&#xa;commit_count INT DEFAULT 0&#xa;branch_count INT DEFAULT 0&#xa;issue_open_count INT DEFAULT 0&#xa;issue_closed_count INT DEFAULT 0&#xa;pr_open_count INT DEFAULT 0&#xa;pr_merged_count INT DEFAULT 0&#xa;latest_commit_hash CHAR(40)&#xa;latest_commit_time TIMESTAMPTZ&#xa;latest_commit_msg TEXT&#xa;updated_at TIMESTAMPTZ DEFAULT NOW()&#xa;IDX idx_repo_stats_updated(updated_at DESC)&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;Bảng phi chuẩn hóa có trigger kiểm soát&#xa;Tối ưu dashboard, giảm COUNT trực tiếp" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="1"><mxGeometry x="1600" y="470" width="450" height="330" as="geometry" /></mxCell>

        <mxCell id="partition" value="Chiến lược phân vùng/quản trị khi dữ liệu lớn&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;1. commits: HASH(repo_id) hoặc RANGE(created_at) để tách lịch sử commit lớn.&#xa;2. issues / pull_requests: HASH(repo_id) hoặc RANGE(created_at) cho truy vấn theo repo/thời gian.&#xa;3. audit_logs: RANGE(created_at) theo tháng/quý vì log tăng liên tục và hay truy vấn theo thời gian.&#xa;4. repositories: thường chưa cần partition sớm; có thể HASH(owner_id/id) khi rất lớn.&#xa;5. repo_stats: không partition; một dòng/repo, dùng index updated_at cho dashboard.&#xa;6. Backup: pg_dump/pg_restore; nâng cao dùng WAL/PITR và replication standby.&#xa;7. RLS/RBAC: repositories, repo_members, commits, issues, pull_requests được bảo vệ bằng policy." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=12;fontSize=14;fontStyle=1" vertex="1" parent="1"><mxGeometry x="520" y="1370" width="1040" height="220" as="geometry" /></mxCell>

        <mxCell id="e1" value="owner_id FK" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="repositories" target="users"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" value="user_id FK" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="repo_members" target="users"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" value="repo_id FK" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="repo_members" target="repositories"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4" value="repo_id FK" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="commits" target="repositories"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e5" value="author_id FK" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="commits" target="users"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e6" value="commit_hash / parent_hash FK" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="commit_parents" target="commits"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e7" value="repo_id FK" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="branches" target="repositories"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e8" value="head_commit_hash FK" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="branches" target="commits"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e9" value="repo_id FK" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="issues" target="repositories"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e10" value="author/assignee FK" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="issues" target="users"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e11" value="repo_id FK" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="pull_requests" target="repositories"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e12" value="author_id FK" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="pull_requests" target="users"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e13" value="merge_commit_hash FK" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="pull_requests" target="commits"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e14" value="pull_request_id FK" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="pull_request_reviews" target="pull_requests"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e15" value="reviewer_id FK" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="pull_request_reviews" target="users"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e16" value="actor_id FK" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="audit_logs" target="users"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e17" value="repo_id FK" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="audit_logs" target="repositories"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e18" value="repo_id PK/FK" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="repo_stats" target="repositories"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
